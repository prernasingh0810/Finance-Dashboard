# Copy to .env and fill in your values.

# Required: MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/finance_dashboard?retryWrites=true&w=majority

# JWT signing secret — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Optional: defaults shown
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Set to "true" to allow new sign-ups after the first user exists (dev only)
ALLOW_PUBLIC_REGISTER=false
